# Postgres (required)
DATABASE_URL=postgres://user:password@localhost:5432/reelforge

# Runtime
PORT=8080
REELFORGE_ENV=development
REELFORGE_INGESTION_V2=true
REELFORGE_STARTUP_RECONCILE=true

# Studio hierarchy API (Phase B — additive; default off)
# REELFORGE_STUDIO_HIERARCHY=true
# REELFORGE_SERIES_API=true
# REELFORGE_STUDIO_SYNC=true

# Platform configuration API (additive; default off)
# REELFORGE_PLATFORM_CONFIG=true

# Monetization metadata API (additive; default off — no payment processing)
# REELFORGE_MONETIZATION=true
# REELFORGE_WATCH_TRACKING=true

# Experience orchestration API (additive; default off — resolver Phase 1a.4)
# REELFORGE_EXPERIENCE_PROFILES=true

# Comma-separated video basenames to skip during startup reconciliation
# REELFORGE_RECONCILE_EXCLUDE=hero-background.mp4

# Public URLs returned in API responses (set to your HTTPS origin in production)
MEDIA_PUBLIC_BASE=http://localhost:8080

# Comma-separated browser origins for CORS (required in production if not using Netlify proxy)
# REELFORGE_CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# Allow *.netlify.app / *.netlify.live in production (default: true when REELFORGE_ENV=production)
# REELFORGE_CORS_ALLOW_NETLIFY=true

# Admin migrate-media and auth
ADMIN_PASSWORD=change-me-in-production

# Signed direct upload (large files bypass Netlify multipart proxy)
# DIRECT_UPLOAD_PUBLIC_BASE=https://your-app.up.railway.app
# SIGNED_UPLOAD_MAX_BYTES=536870912
# SIGNED_UPLOAD_TTL_SECONDS=3600

# Cloudflare R2 (when set, signed uploads PUT directly to R2; Railway stores metadata only)
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_BUCKET=reelforge-uploads
# R2_BUCKET_NAME=reelforge-uploads
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_SECRET_KEY=...
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
# R2_KEY_PREFIX=prod
# Legacy aliases also supported: UPLOADS_S3_BUCKET, UPLOADS_S3_ENDPOINT, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, UPLOADS_KEY_PREFIX, UPLOADS_PUBLIC_BASE
